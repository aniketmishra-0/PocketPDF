<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/viewer_background">

    <com.renameapk.pdfzip.ZoomableImageView
        android:id="@+id/pageImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/pageNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="8dp"
        android:layout_marginEnd="6dp"
        android:background="@drawable/bg_status_panel"
        android:paddingLeft="7dp"
        android:paddingTop="4dp"
        android:paddingRight="7dp"
        android:paddingBottom="4dp"
        android:textColor="@color/title_text"
        android:textSize="9sp"
        android:textStyle="bold" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/pageLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:indicatorColor="@color/progress_color" />

    <TextView
        android:id="@+id/pageError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_note_panel"
        android:padding="12dp"
        android:text="@string/viewer_render_error"
        android:textColor="@color/title_text"
        android:textStyle="bold"
        android:visibility="gone" />
</FrameLayout>
