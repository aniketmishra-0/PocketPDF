<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:padding="6dp"
    android:scrollbars="none">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/card_surface_strong"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/card_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/visual_edit_text_title"
                android:textColor="@color/title_text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/visual_edit_text_dialog_subtitle"
                android:textColor="@color/body_text"
                android:textSize="13sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/addTextInputLayout"
                style="@style/Widget.PDFZipExporter.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/visual_edit_text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/addTextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top|start"
                    android:inputType="textCapSentences|textMultiLine|textAutoCorrect"
                    android:longClickable="true"
                    android:maxLines="5"
                    android:minLines="3"
                    android:textColor="@color/title_text"
                    android:textColorHint="@color/body_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/addTextBoldToggle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/visual_edit_text_bold"
                    android:textColor="@color/title_text" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pasteClipboardButton"
                    style="@style/Widget.PDFZipExporter.Button.MiniTool"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/visual_edit_text_paste" />
            </LinearLayout>

            <TextView
                android:id="@+id/addTextColorLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/visual_edit_text_color_title"
                android:textColor="@color/title_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/addTextColorGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp"
                app:singleLine="false"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/addTextColorInkChip"
                    style="@style/Widget.PDFZipExporter.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/visual_edit_text_color_ink"
                    android:textColor="@color/title_text" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/addTextColorBlackChip"
                    style="@style/Widget.PDFZipExporter.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/visual_edit_text_color_black"
                    android:textColor="@color/title_text" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/addTextColorWhiteChip"
                    style="@style/Widget.PDFZipExporter.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/visual_edit_text_color_white"
                    android:textColor="@color/title_text" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/addTextColorCoralChip"
                    style="@style/Widget.PDFZipExporter.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/visual_edit_text_color_coral"
                    android:textColor="@color/progress_color" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/addTextColorBlueChip"
                    style="@style/Widget.PDFZipExporter.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/visual_edit_text_color_blue"
                    android:textColor="@color/document_accent" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/addTextColorGreenChip"
                    style="@style/Widget.PDFZipExporter.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/visual_edit_text_color_green"
                    android:textColor="@color/tool_green_text" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/addTextColorRoseChip"
                    style="@style/Widget.PDFZipExporter.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/visual_edit_text_color_rose"
                    android:textColor="@color/tool_rose_text" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/addTextColorGoldChip"
                    style="@style/Widget.PDFZipExporter.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/visual_edit_text_color_gold"
                    android:textColor="@color/tool_gold_text" />
            </com.google.android.material.chip.ChipGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/addTextCancelButton"
                    style="@style/Widget.PDFZipExporter.Button.Outline"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="@android:string/cancel" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="wrap_content" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/addTextConfirmButton"
                    style="@style/Widget.PDFZipExporter.Button.Primary"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="@string/visual_edit_text_add" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</ScrollView>
