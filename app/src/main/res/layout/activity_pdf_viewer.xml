<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/viewer_background"
    android:keepScreenOn="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/viewerToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_surface_strong"
        android:elevation="0dp"
        android:minHeight="56dp"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:subtitleTextColor="@color/body_text"
        app:titleTextColor="@color/title_text" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.renameapk.pdfzip.LockableRecyclerView
            android:id="@+id/viewerPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:scrollbars="none" />

        <LinearLayout
            android:id="@+id/viewerLoadingGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:indicatorColor="@color/progress_color" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/viewer_loading_pdf"
                android:textColor="@color/title_text"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/viewerErrorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="24dp"
            android:background="@drawable/bg_note_panel"
            android:gravity="center"
            android:padding="24dp"
            android:textColor="@color/title_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/readerQuickActionsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="18dp"
            android:contentDescription="@string/viewer_open_tools"
            android:visibility="gone"
            app:backgroundTint="@color/progress_color"
            app:elevation="0dp"
            app:fabSize="mini"
            app:maxImageSize="20dp"
            app:srcCompat="@drawable/ic_reader_tools_24"
            app:tint="@android:color/white" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/viewerControlsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_reader_controls"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/viewerDocumentMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/viewer_loading_pdf"
            android:textColor="@color/title_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/viewerZoomHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/viewer_zoom_hint"
            android:textColor="@color/body_text"
            android:textSize="11sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/viewerFitControlsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/viewerFitModeToggleGroup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:checkedButton="@id/readerFitPageButton"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/readerFitPageButton"
                    style="@style/Widget.PDFZipExporter.Button.Toggle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/viewer_fit_page" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/readerFitWidthButton"
                    style="@style/Widget.PDFZipExporter.Button.Toggle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/viewer_fit_width" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <Space
                android:layout_width="10dp"
                android:layout_height="wrap_content" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/resetReaderZoomButton"
                style="@style/Widget.PDFZipExporter.Button.MiniTool"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minWidth="0dp"
                android:text="@string/viewer_reset_zoom" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/jumpToPageButton"
                style="@style/Widget.PDFZipExporter.Button.MiniTool"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:text="@string/viewer_jump" />

            <Space
                android:layout_width="10dp"
                android:layout_height="wrap_content" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/shareDocumentButton"
                style="@style/Widget.PDFZipExporter.Button.MiniTool"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:text="@string/viewer_share" />

            <Space
                android:layout_width="10dp"
                android:layout_height="wrap_content" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/toggleThumbnailStripButton"
                style="@style/Widget.PDFZipExporter.Button.MiniTool"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:text="@string/viewer_show_pages" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/viewer_reading_mode_title"
            android:textColor="@color/title_text"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/readerModeToggleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:checkedButton="@id/scrollModeButton"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/scrollModeButton"
                style="@style/Widget.PDFZipExporter.Button.Toggle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/viewer_scroll_mode" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/swipeModeButton"
                style="@style/Widget.PDFZipExporter.Button.Toggle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/viewer_swipe_mode" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:id="@+id/bookmarkSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/title_text"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/bookmarkEmptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/viewer_bookmarks_empty"
            android:textColor="@color/body_text"
            android:textSize="12sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/bookmarkRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingEnd="8dp"
            android:scrollbars="none"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/previousPageButton"
                style="@style/Widget.PDFZipExporter.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="0dp"
                android:text="@string/viewer_previous"
                android:visibility="gone"
                app:icon="@drawable/ic_chevron_left_24"
                app:iconGravity="textStart" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/viewerPageIndicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/viewer_loading_pdf"
                    android:textColor="@color/title_text"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <SeekBar
                    android:id="@+id/pageSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:max="0"
                    android:progress="0" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/nextPageButton"
                style="@style/Widget.PDFZipExporter.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="0dp"
                android:text="@string/viewer_next"
                android:visibility="gone"
                app:icon="@drawable/ic_chevron_right_24"
                app:iconGravity="textEnd" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/viewer_controls_hint"
            android:textColor="@color/body_text"
            android:textSize="12sp"
            android:visibility="gone" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/thumbnailStripContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_surface_strong"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/viewer_thumbnail_strip_title"
                        android:textColor="@color/title_text"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/thumbnailStripMetaText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/viewer_thumbnail_strip_hint"
                        android:textColor="@color/body_text"
                        android:textSize="11sp" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/thumbnailRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="84dp"
                    android:layout_marginTop="8dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:paddingStart="2dp"
                    android:paddingEnd="8dp"
                    android:scrollbars="none" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</LinearLayout>
