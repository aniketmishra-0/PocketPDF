<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/viewer_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/editToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_surface_strong"
        android:elevation="0dp"
        android:minHeight="56dp"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:subtitleTextColor="@color/body_text"
        app:titleTextColor="@color/title_text" />

    <TextView
        android:id="@+id/editSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_surface_strong"
        android:paddingStart="16dp"
        android:paddingTop="0dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:text="@string/visual_edit_subtitle"
        android:textColor="@color/body_text"
        android:textSize="13sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <HorizontalScrollView
            android:id="@+id/editHorizontalScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:scrollbars="none">

            <androidx.core.widget.NestedScrollView
                android:id="@+id/editScrollView"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:paddingStart="12dp"
                android:paddingTop="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="12dp"
                android:scrollbars="none">

                <FrameLayout
                    android:id="@+id/editCanvasViewport"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center">

                    <FrameLayout
                        android:id="@+id/editCanvasFrame"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_document_sheet">

                        <ImageView
                            android:id="@+id/editPageImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@null"
                            android:scaleType="fitXY" />

                        <com.renameapk.pdfzip.PdfMarkupOverlayView
                            android:id="@+id/editOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </FrameLayout>
                </FrameLayout>
            </androidx.core.widget.NestedScrollView>
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/editLoadingGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:indicatorColor="@color/progress_color" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/visual_edit_loading"
                android:textColor="@color/title_text"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/editErrorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="24dp"
            android:background="@drawable/bg_note_panel"
            android:gravity="center"
            android:padding="24dp"
            android:textColor="@color/title_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/editZoomButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/editZoomInButton"
                style="@style/Widget.PDFZipExporter.Button.MiniTool"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:contentDescription="@string/visual_edit_zoom_in"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:text=""
                app:icon="@drawable/ic_zoom_in_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/title_text" />

            <Space
                android:layout_width="wrap_content"
                android:layout_height="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/editZoomOutButton"
                style="@style/Widget.PDFZipExporter.Button.MiniTool"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:contentDescription="@string/visual_edit_zoom_out"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:text=""
                app:icon="@drawable/ic_zoom_out_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/title_text" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/editControlsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_reader_controls"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/editNavigationCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/editPageMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/visual_edit_loading"
                    android:textColor="@color/title_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/editToolHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/visual_edit_hint"
                    android:textColor="@color/body_text"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/editPreviousPageButton"
                        style="@style/Widget.PDFZipExporter.Button.MiniTool"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:minWidth="0dp"
                        android:text="@string/viewer_previous"
                        app:icon="@drawable/ic_chevron_left_24"
                        app:iconGravity="textStart" />

                    <TextView
                        android:id="@+id/editPageIndicator"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_document_sheet"
                        android:gravity="center"
                        android:minHeight="40dp"
                        android:paddingStart="10dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="8dp"
                        android:textColor="@color/title_text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/editNextPageButton"
                        style="@style/Widget.PDFZipExporter.Button.MiniTool"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:minWidth="0dp"
                        android:text="@string/viewer_next"
                        app:icon="@drawable/ic_chevron_right_24"
                        app:iconGravity="textEnd"
                        app:iconPadding="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/editJumpRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/editJumpToPageButton"
                        style="@style/Widget.PDFZipExporter.Button.MiniTool"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:minWidth="0dp"
                        android:text="@string/viewer_jump"
                        app:icon="@drawable/ic_tool_jump_24"
                        app:iconGravity="textStart" />

                    <SeekBar
                        android:id="@+id/editPageSeekBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:max="0"
                        android:progress="0"
                        android:progressBackgroundTint="@color/progress_track"
                        android:progressTint="@color/progress_color"
                        android:splitTrack="false"
                        android:thumbTint="@color/progress_color" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/editToolsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@color/card_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/editToolToggleGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:checkedButton="@id/moveToolButton"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/moveToolButton"
                        style="@style/Widget.PDFZipExporter.Button.Toggle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/visual_edit_move"
                        app:icon="@drawable/ic_tool_move_24"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        app:iconTint="@color/toggle_button_text" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/drawToolButton"
                        style="@style/Widget.PDFZipExporter.Button.Toggle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/visual_edit_draw"
                        app:icon="@drawable/ic_tool_draw_24"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        app:iconTint="@color/toggle_button_text" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/highlightToolButton"
                        style="@style/Widget.PDFZipExporter.Button.Toggle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/visual_edit_highlight"
                        app:icon="@drawable/ic_tool_highlight_24"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        app:iconTint="@color/toggle_button_text" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <LinearLayout
                    android:id="@+id/editHistoryRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/addTextButton"
                        style="@style/Widget.PDFZipExporter.Button.MiniTool"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:text="@string/visual_edit_tool_text"
                        app:icon="@drawable/ic_tool_text_24"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        app:iconTint="@color/title_text" />

                    <Space
                        android:id="@+id/editPrimaryActionsSpacerStart"
                        android:layout_width="8dp"
                        android:layout_height="wrap_content" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/addImageButton"
                        style="@style/Widget.PDFZipExporter.Button.MiniTool"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:text="@string/visual_edit_tool_image"
                        app:icon="@drawable/ic_tool_image_24"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        app:iconTint="@color/title_text" />

                    <Space
                        android:id="@+id/editPrimaryActionsSpacerEnd"
                        android:layout_width="8dp"
                        android:layout_height="wrap_content" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/moreToolsButton"
                        style="@style/Widget.PDFZipExporter.Button.MiniTool"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:text="@string/visual_edit_tool_tools"
                        app:icon="@drawable/ic_tool_more_24"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        app:iconTint="@color/title_text" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/editSelectedCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/editUndoRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/selectedSmallerButton"
                    style="@style/Widget.PDFZipExporter.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="@string/visual_edit_smaller" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="wrap_content" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/selectedLargerButton"
                    style="@style/Widget.PDFZipExporter.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="@string/visual_edit_larger" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="wrap_content" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/toggleBoldButton"
                    style="@style/Widget.PDFZipExporter.Button.Outline"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="@string/visual_edit_bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/editActionsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/selectionOnlyStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_feature_pill"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="8dp"
                    android:textColor="@color/title_text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/pageNumbersGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="8dp"
                    app:chipSpacingVertical="8dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/pageNumbersChip"
                        style="@style/Widget.PDFZipExporter.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checkable="true"
                        android:text="@string/visual_edit_page_numbers" />
                </com.google.android.material.chip.ChipGroup>

                <LinearLayout
                    android:id="@+id/editUndoActionsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/deletePageButton"
                        style="@style/Widget.PDFZipExporter.Button.Outline"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:text="@string/visual_edit_delete_page" />

                    <Space
                        android:id="@+id/deletePageSpacerOne"
                        android:layout_width="8dp"
                        android:layout_height="wrap_content" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/undoEditButton"
                        style="@style/Widget.PDFZipExporter.Button.Secondary"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:text="@string/visual_edit_undo" />

                    <Space
                        android:id="@+id/deletePageSpacerTwo"
                        android:layout_width="8dp"
                        android:layout_height="wrap_content" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/clearPageButton"
                        style="@style/Widget.PDFZipExporter.Button.Outline"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:text="@string/visual_edit_clear_page" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/previewEditedPdfButton"
                style="@style/Widget.PDFZipExporter.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="@string/visual_edit_preview_compact" />

            <Space
                android:layout_width="8dp"
                android:layout_height="wrap_content" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveEditedPdfButton"
                style="@style/Widget.PDFZipExporter.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="@string/visual_edit_save_compact"
                app:icon="@drawable/ic_tool_save_24"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@android:color/white" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
