<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_reader_controls"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="14dp"
    android:paddingEnd="20dp"
    android:paddingBottom="26dp">

    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_sheet_handle" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/visual_edit_reorder_title"
        android:textColor="@color/title_text"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/visual_edit_reorder_subtitle"
        android:textColor="@color/body_text"
        android:textSize="13sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/reorderPagesQuickMoveButton"
        style="@style/Widget.PDFZipExporter.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="14dp"
        android:text="@string/visual_edit_reorder_quick_move" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/reorderPagesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginTop="14dp"
        android:clipToPadding="false"
        android:paddingBottom="6dp"
        android:scrollbars="vertical" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/reorderPagesDoneButton"
        style="@style/Widget.PDFZipExporter.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="14dp"
        android:text="@string/visual_edit_reorder_done" />
</LinearLayout>
