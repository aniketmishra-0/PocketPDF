<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homeEntryCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/card_surface"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/homeEntryBadgeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_feature_pill"
                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                android:paddingBottom="5dp"
                android:textColor="@color/button_secondary_text"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/homeEntryTimeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/body_text"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/homeEntryTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/title_text"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/homeEntrySubtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/body_text"
            android:textSize="13sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/homeEntryMetaText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/body_text"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/homeEntryActionButton"
            style="@style/Widget.PDFZipExporter.Button.Secondary"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginTop="14dp"
            android:minWidth="0dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
